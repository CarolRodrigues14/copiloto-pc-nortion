# URL do projeto Supabase
SUPABASE_URL=https://your-project-ref.supabase.co

# Chave de serviço do Supabase para operações do backend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Porta usada pelo backend (Render define isso automaticamente)
PORT=3000

# URL do frontend permitido pelo CORS
FRONTEND_URL=http://localhost:5173

# Endpoint do orquestrador
ORCHESTRATOR_URL=http://localhost:3002
